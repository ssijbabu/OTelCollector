# syntax=docker/dockerfile:1
#
# Three-stage build following the OCB guide:
# https://opentelemetry.io/docs/collector/extend/ocb/
#
# Build context must be the repo root so the local receiver and exporter
# source folders are accessible:
#   docker build -f otelcollector/Dockerfile -t otelcollector:latest .
#
# Stage 1 — certs   : pull CA bundle from Alpine
# Stage 2 — builder : install OCB, generate sources, compile
# Stage 3 — runtime : distroless minimal image

ARG BINARY_NAME=OTelCollector

# ── Stage 1: CA certificates ────────────────────────────────────────────────
FROM alpine:3.21 AS certs
RUN apk --no-cache add ca-certificates

# ── Stage 2: Build ──────────────────────────────────────────────────────────
FROM golang:1.26 AS builder
ARG BINARY_NAME

# Set WORKDIR to otelcollector so that the go.mod replace directives
# (=> ../azureeventhubreceiver, => ../azureeventhubexporter) resolve correctly
WORKDIR /build/otelcollector

# Install OCB — cached across rebuilds via BuildKit mount
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    go install go.opentelemetry.io/collector/cmd/builder@v0.152.0

# Copy local source packages alongside the main module so the replace
# directives generated by OCB (=> ../azureeventhubreceiver etc.) resolve
COPY azureeventhubexporter/ /build/azureeventhubexporter/
COPY azureeventhubreceiver/ /build/azureeventhubreceiver/

# Copy the manifest — OCB generates main.go / components.go / go.mod from it
COPY otelcollector/manifest.yaml .

# Generate sources. --skip-compilation lets us patch go.mod before the build.
RUN --mount=type=cache,target=/go/pkg/mod \
    builder --config manifest.yaml --skip-compilation

# Pin two transitive EDOT deps that OCB resolves to versions incompatible
# with contrib v0.152.0 (API breakage in ottldatapoint + missing symbol):
#   lsmintervalprocessor v0.8.0  → v0.50.0 (fixes *TransformContext pointer API)
#   elasticattr          v0.40.0 → v0.50.0 (adds MetadataDynamicResourceAttributes)
RUN sed -i \
        's|opentelemetry-collector-components/internal/elasticattr v0.40.0|opentelemetry-collector-components/internal/elasticattr v0.50.0|' \
        go.mod && \
    sed -i \
        's|opentelemetry-collector-components/processor/lsmintervalprocessor v0.8.0|opentelemetry-collector-components/processor/lsmintervalprocessor v0.50.0|' \
        go.mod

# Resolve dependency graph then compile a static Linux binary
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    go mod tidy && \
    CGO_ENABLED=0 GOOS=linux \
    go build -trimpath -ldflags="-s -w" -o "${BINARY_NAME}" .

# ── Stage 3: Runtime ────────────────────────────────────────────────────────
FROM gcr.io/distroless/base-debian12:nonroot
ARG BINARY_NAME

COPY --from=certs /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY --from=builder "/build/otelcollector/${BINARY_NAME}" /otelcollector
COPY otelcollector/collector-config.yaml /etc/otelcol/config.yaml

EXPOSE 4317 4318 13133

ENTRYPOINT ["/otelcollector"]
CMD ["--config", "/etc/otelcol/config.yaml"]
